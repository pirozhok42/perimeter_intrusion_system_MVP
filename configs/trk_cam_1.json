{
  "camera_id": "trk_cam_1",
  "camera_type": "territory",
  "app_role": "tracking",
  "is_configured": true,
  "model": {
    "weights": "yolo11s.pt",
    "confidence_threshold": 0.35,
    "iou_threshold": 0.5,
    "classes": {
      "person": 0,
      "car": 2,
      "motorcycle": 3,
      "bus": 5,
      "truck": 7
    },
    "enabled_classes": [
      "person"
    ]
  },
  "reid": {
