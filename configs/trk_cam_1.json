    "device": "cuda",
    "reid_update_every_n_frames": 10
  },
  "zones": {
    "fence_line": [],
    "sterile_zone": [],
    "fence_touch_threshold_px": 12
  },
  "events": {
    "dedup_seconds": 1.0
  },
  "output": {
    "videos_dir": "processed/videos",
    "logs_dir": "processed/logs"
  }
